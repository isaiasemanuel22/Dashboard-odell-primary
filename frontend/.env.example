# Copiá a .env (y opcionalmente .env.local para overrides personales)
# Desarrollo local: el frontend NO debe apuntar a producción.

# URL del API que usa Angular (dev: proxy relativo → backend local)
API_URL=/api

# Destino del proxy de ng serve (backend local)
API_PROXY_TARGET=http://localhost:3000

# backend = uploads locales | firebase = Firebase Storage (prod)
PRODUCT_IMAGE_STORAGE=backend

# Firebase client (login). Podés dejar los defaults del proyecto Odell.
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=
# FIREBASE_MESSAGING_SENDER_ID=
# FIREBASE_APP_ID=
