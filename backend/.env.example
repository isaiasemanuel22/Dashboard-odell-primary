# MySQL — ajustá usuario, contraseña, host y nombre de base
DATABASE_URL="mysql://odell:TU_PASSWORD@localhost:3306/odell_dashboard"

# Puerto del API (default 3000)
# PORT=3000

# Entorno: development | production
# NODE_ENV=development

# Orígenes permitidos del frontend (separados por coma)
CORS_ORIGINS=http://localhost:4200

# AUTO_SEED=true carga datos demo si la base está vacía al iniciar
AUTO_SEED=false

# En producción, DATABASE_URL y Firebase son obligatorios por defecto.
# Podés forzar requisitos también en desarrollo:
# REQUIRE_DATABASE=true
# REQUIRE_AUTH=true

# Firebase Admin — JSON de cuenta de servicio (ver docs/FIREBASE.md)
# FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
# FIREBASE_STORAGE_BUCKET=dashboard-odell-2.firebasestorage.app
# PRODUCT_IMAGE_STORAGE=firebase
