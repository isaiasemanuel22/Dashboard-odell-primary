# Copiá a .env (y opcionalmente .env.local para overrides personales)
# Desarrollo local — NO uses la base ni credenciales de producción.

NODE_ENV=development
PORT=3000

# MySQL local
DATABASE_URL="mysql://odell:TU_PASSWORD@localhost:3306/odell_dashboard"

# Frontend local (ng serve)
CORS_ORIGINS=http://localhost:4200

# Datos demo si la base está vacía
AUTO_SEED=false

# Imágenes: backend = /uploads local | firebase = Firebase Storage
# En producción el default es firebase (si Firebase Admin está configurado).
PRODUCT_IMAGE_STORAGE=backend

# Auth Firebase opcional en dev (si no está, algunas rutas pueden fallar)
# REQUIRE_AUTH=false
# REQUIRE_DATABASE=false

# Firebase Admin — solo si necesitás auth/upload con Firebase en local
# FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
# FIREBASE_STORAGE_BUCKET=dashboard-odell-2.firebasestorage.app
